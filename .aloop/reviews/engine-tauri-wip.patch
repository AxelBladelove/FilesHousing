diff --git a/src-tauri/src/main.rs b/src-tauri/src/main.rs
new file mode 100644
index 0000000..0ddc222
--- /dev/null
+++ b/src-tauri/src/main.rs
@@ -0,0 +1,784 @@
+#![cfg_attr(not(debug_assertions), windows_subsystem = "windows")]
+
+use serde::Serialize;
+use std::{
+    fs,
+    path::{Path, PathBuf},
+    time::{Instant, SystemTime},
+};
+
+const TOP_CHILDREN: usize = 33;
+const ROOT_CHILDREN: usize = 48;
+const MAX_SCAN_DEPTH: usize = 128;
+
+#[derive(Clone, Copy, Serialize)]
+#[serde(rename_all = "lowercase")]
+enum Cat {
+    Video,
+    Image,
+    Audio,
+    Doc,
+    Code,
+    Archive,
+    App,
+    Game,
+    System,
+    Data,
+    Other,
+}
+
+impl Cat {
+    fn index(self) -> usize {
+        self as usize
+    }
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct FsNode {
+    id: u32,
+    name: String,
+    kind: &'static str,
+    cat: Cat,
+    size: u64,
+    days: f64,
+    count: u64,
+    #[serde(skip_serializing_if = "Option::is_none")]
+    children: Option<Vec<FsNode>>,
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct DiskSummary {
+    letter: String,
+    label: String,
+    total_bytes: u64,
+    used_bytes: u64,
+    available_bytes: u64,
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct Disk {
+    letter: String,
+    label: String,
+    total_bytes: u64,
+    root: FsNode,
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct CleanupError {
+    path: String,
+    error: String,
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct CleanupResult {
+    requested: usize,
+    recycled: usize,
+    failed: usize,
+    recycled_paths: Vec<String>,
+    errors: Vec<CleanupError>,
+}
+
+#[derive(Clone)]
+struct CatSizes([u64; 11]);
+
+impl CatSizes {
+    fn new() -> Self {
+        Self([0; 11])
+    }
+
+    fn add(&mut self, cat: Cat, size: u64) {
+        self.0[cat.index()] = self.0[cat.index()].saturating_add(size);
+    }
+
+    fn dominant(&self) -> Cat {
+        let mut best = Cat::Other;
+        let mut best_size = 0;
+        for (idx, size) in self.0.iter().enumerate() {
+            if *size > best_size {
+                best_size = *size;
+                best = match idx {
+                    0 => Cat::Video,
+                    1 => Cat::Image,
+                    2 => Cat::Audio,
+                    3 => Cat::Doc,
+                    4 => Cat::Code,
+                    5 => Cat::Archive,
+                    6 => Cat::App,
+                    7 => Cat::Game,
+                    8 => Cat::System,
+                    9 => Cat::Data,
+                    _ => Cat::Other,
+                };
+            }
+        }
+        if best_size == 0 {
+            Cat::Other
+        } else {
+            best
+        }
+    }
+}
+
+struct NodeStats {
+    size: u64,
+    count: u64,
+    days: f64,
+    cats: CatSizes,
+}
+
+impl NodeStats {
+    fn new() -> Self {
+        Self {
+            size: 0,
+            count: 0,
+            days: f64::INFINITY,
+            cats: CatSizes::new(),
+        }
+    }
+
+    fn add_node(&mut self, node: &FsNode) {
+        self.size = self.size.saturating_add(node.size);
+        self.count = self.count.saturating_add(node.count);
+        self.days = self.days.min(node.days);
+        self.cats.add(node.cat, node.size);
+    }
+
+    fn days(&self) -> f64 {
+        if self.days.is_finite() {
+            self.days
+        } else {
+            0.0
+        }
+    }
+}
+
+struct RestAgg {
+    size: u64,
+    count: u64,
+    days: f64,
+    cats: CatSizes,
+}
+
+impl RestAgg {
+    fn new() -> Self {
+        Self {
+            size: 0,
+            count: 0,
+            days: f64::INFINITY,
+            cats: CatSizes::new(),
+        }
+    }
+
+    fn add_node(&mut self, node: FsNode) {
+        self.size = self.size.saturating_add(node.size);
+        self.count = self.count.saturating_add(node.count);
+        self.days = self.days.min(node.days);
+        self.cats.add(node.cat, node.size);
+    }
+}
+
+struct ChildAccumulator {
+    shown: Vec<FsNode>,
+    rest: RestAgg,
+    stats: NodeStats,
+    limit: usize,
+}
+
+impl ChildAccumulator {
+    fn new(limit: usize) -> Self {
+        Self {
+            shown: Vec::with_capacity(limit + 1),
+            rest: RestAgg::new(),
+            stats: NodeStats::new(),
+            limit,
+        }
+    }
+
+    fn add(&mut self, child: FsNode) {
+        self.stats.add_node(&child);
+        if child.size == 0 {
+            return;
+        }
+        if self.shown.len() < self.limit {
+            self.shown.push(child);
+            return;
+        }
+
+        // K <= 48, so this O(entries * K) scan avoids heap churn on the hot path.
+        let mut min_idx = 0;
+        let mut min_size = self.shown[0].size;
+        for (idx, node) in self.shown.iter().enumerate().skip(1) {
+            if node.size < min_size {
+                min_idx = idx;
+                min_size = node.size;
+            }
+        }
+
+        if child.size > min_size {
+            let evicted = self.shown.swap_remove(min_idx);
+            self.rest.add_node(evicted);
+            self.shown.push(child);
+        } else {
+            self.rest.add_node(child);
+        }
+    }
+
+    fn finish(mut self, path: &Path) -> (Vec<FsNode>, NodeStats) {
+        self.shown.sort_unstable_by(|a, b| b.size.cmp(&a.size));
+        if self.rest.size > 0 {
+            let rest_count = self.rest.count;
+            self.shown.push(FsNode {
+                id: stable_rest_id(path),
+                name: format!("{} smaller items", rest_count),
+                kind: "rest",
+                cat: self.rest.cats.dominant(),
+                size: self.rest.size,
+                days: if self.rest.days.is_finite() {
+                    self.rest.days
+                } else {
+                    0.0
+                },
+                count: rest_count,
+                children: None,
+            });
+            self.shown.sort_unstable_by(|a, b| b.size.cmp(&a.size));
+        }
+        (self.shown, self.stats)
+    }
+}
+
+#[tauri::command]
+fn list_disks() -> Vec<DiskSummary> {
+    platform_list_disks()
+}
+
+#[tauri::command]
+fn scan_disk(letter: String) -> Result<Disk, String> {
+    let drive = normalize_drive_letter(&letter)?;
+    let root_path = PathBuf::from(format!("{drive}:\\"));
+    let summary = disk_summary_for_root(drive, &root_path)?;
+    let started = Instant::now();
+    let root = scan_dir(&root_path, format!("{drive}:"), 0, SystemTime::now());
+    eprintln!(
+        "fileshousing scan {drive}: {} files, {} bytes in {:.2?}",
+        root.count,
+        root.size,
+        started.elapsed()
+    );
+    Ok(Disk {
+        letter: drive.to_string(),
+        label: summary.label,
+        total_bytes: summary.total_bytes,
+        root,
+    })
+}
+
+#[tauri::command]
+fn open_in_explorer(path: String) -> Result<(), String> {
+    let path = normalize_user_path(&path)?;
+    platform_open_in_explorer(&path)
+}
+
+#[tauri::command]
+fn recycle_paths(paths: Vec<String>) -> CleanupResult {
+    let requested = paths.len();
+    let mut recycled_paths = Vec::new();
+    let mut errors = Vec::new();
+
+    for raw in paths {
+        match normalize_user_path(&raw)
+            .and_then(|path| validate_recycle_target(&path).map(|_| path))
+            .and_then(|path| platform_recycle_one(&path).map(|_| path))
+        {
+            Ok(path) => recycled_paths.push(path.to_string_lossy().into_owned()),
+            Err(error) => errors.push(CleanupError { path: raw, error }),
+        }
+    }
+
+    CleanupResult {
+        requested,
+        recycled: recycled_paths.len(),
+        failed: errors.len(),
+        recycled_paths,
+        errors,
+    }
+}
+
+fn scan_dir(path: &Path, name: String, depth: usize, now: SystemTime) -> FsNode {
+    if depth >= MAX_SCAN_DEPTH {
+        return FsNode {
+            id: stable_path_id(path),
+            name,
+            kind: "dir",
+            cat: Cat::Other,
+            size: 0,
+            days: 0.0,
+            count: 0,
+            children: None,
+        };
+    }
+
+    let limit = if depth == 0 { ROOT_CHILDREN } else { TOP_CHILDREN };
+    let mut acc = ChildAccumulator::new(limit);
+
+    if let Ok(read_dir) = fs::read_dir(path) {
+        for entry in read_dir.flatten() {
+            if let Some(child) = scan_entry(&entry.path(), entry.file_name().to_string_lossy().into_owned(), depth + 1, now) {
+                acc.add(child);
+            }
+        }
+    }
+
+    let (children, stats) = acc.finish(path);
+    FsNode {
+        id: stable_path_id(path),
+        name,
+        kind: "dir",
+        cat: stats.cats.dominant(),
+        size: stats.size,
+        days: stats.days(),
+        count: stats.count,
+        children: if children.is_empty() { None } else { Some(children) },
+    }
+}
+
+fn scan_entry(path: &Path, name: String, depth: usize, now: SystemTime) -> Option<FsNode> {
+    let metadata = fs::symlink_metadata(path).ok()?;
+    if is_reparse_or_symlink(&metadata) {
+        return None;
+    }
+
+    if metadata.is_dir() {
+        Some(scan_dir(path, name, depth, now))
+    } else if metadata.is_file() {
+        Some(FsNode {
+            id: stable_path_id(path),
+            cat: categorize_file(path, &name),
+            name,
+            kind: "file",
+            size: metadata.len(),
+            days: metadata
+                .modified()
+                .ok()
+                .and_then(|modified| now.duration_since(modified).ok())
+                .map(|duration| duration.as_secs_f64() / 86_400.0)
+                .unwrap_or(0.0),
+            count: 1,
+            children: None,
+        })
+    } else {
+        None
+    }
+}
+
+fn categorize_file(path: &Path, name: &str) -> Cat {
+    if is_system_file(name) || has_path_component(path, &["Windows", "System Volume Information", "$Recycle.Bin"]) {
+        return Cat::System;
+    }
+    if has_path_component(path, &["steamapps", "XboxGames"]) {
+        return Cat::Game;
+    }
+
+    let ext = path.extension().and_then(|ext| ext.to_str()).unwrap_or("");
+    if ext_in(ext, &["mp4", "mkv", "mov", "avi", "wmv", "webm", "m4v", "flv", "braw", "r3d", "mts", "m2ts"]) {
+        Cat::Video
+    } else if ext_in(ext, &["jpg", "jpeg", "png", "gif", "bmp", "svg", "webp", "heic", "tif", "tiff", "raw", "psd", "ai"]) {
+        Cat::Image
+    } else if ext_in(ext, &["mp3", "wav", "flac", "m4a", "aac", "ogg", "wma"]) {
+        Cat::Audio
+    } else if ext_in(ext, &["pdf", "doc", "docx", "xls", "xlsx", "ppt", "pptx", "txt", "rtf", "md", "csv", "epub", "one"]) {
+        Cat::Doc
+    } else if ext_in(ext, &["rs", "ts", "tsx", "js", "jsx", "py", "go", "java", "cs", "cpp", "c", "h", "hpp", "json", "toml", "yaml", "yml", "html", "css", "scss", "sql", "php", "rb", "swift", "kt", "lock", "xml"]) {
+        Cat::Code
+    } else if ext_in(ext, &["zip", "rar", "7z", "tar", "gz", "bz2", "xz", "iso", "cab", "tgz", "zst"]) {
+        Cat::Archive
+    } else if ext_in(ext, &["exe", "msi", "dll", "sys", "com", "bat", "cmd", "ps1", "appx", "msix", "jar"]) || has_path_component(path, &["Program Files", "Program Files (x86)"]) {
+        Cat::App
+    } else if ext_in(ext, &["db", "sqlite", "sqlite3", "parquet", "dat", "bin", "blob", "ldb", "log", "cache"]) {
+        Cat::Data
+    } else {
+        Cat::Other
+    }
+}
+
+fn ext_in(ext: &str, values: &[&str]) -> bool {
+    values.iter().any(|value| ext.eq_ignore_ascii_case(value))
+}
+
+fn is_system_file(name: &str) -> bool {
+    ["pagefile.sys", "hiberfil.sys", "swapfile.sys"]
+        .iter()
+        .any(|value| name.eq_ignore_ascii_case(value))
+}
+
+fn has_path_component(path: &Path, names: &[&str]) -> bool {
+    path.components().any(|component| {
+        component
+            .as_os_str()
+            .to_str()
+            .is_some_and(|value| names.iter().any(|name| value.eq_ignore_ascii_case(name)))
+    })
+}
+
+fn normalize_drive_letter(input: &str) -> Result<char, String> {
+    let trimmed = input.trim().trim_end_matches(':');
+    let mut chars = trimmed.chars();
+    match (chars.next(), chars.next()) {
+        (Some(ch), None) if ch.is_ascii_alphabetic() => Ok(ch.to_ascii_uppercase()),
+        _ => Err("Expected a drive letter like C.".to_string()),
+    }
+}
+
+fn normalize_user_path(input: &str) -> Result<PathBuf, String> {
+    let trimmed = input.trim();
+    if trimmed.is_empty() {
+        return Err("Path is empty.".to_string());
+    }
+    if trimmed.len() == 2 && trimmed.as_bytes()[1] == b':' && trimmed.as_bytes()[0].is_ascii_alphabetic() {
+        return Ok(PathBuf::from(format!("{}:\\", trimmed.as_bytes()[0].to_ascii_uppercase() as char)));
+    }
+    Ok(PathBuf::from(trimmed))
+}
+
+fn validate_recycle_target(path: &Path) -> Result<(), String> {
+    if !path.exists() {
+        return Err("Path does not exist.".to_string());
+    }
+    let metadata = fs::symlink_metadata(path).map_err(|error| format!("Unable to inspect path: {error}"))?;
+    if is_reparse_or_symlink(&metadata) {
+        return Err("Protected reparse point.".to_string());
+    }
+    if path.file_name().is_none() {
+        return Err("Refusing to recycle a drive root.".to_string());
+    }
+    if let Some(name) = path.file_name().and_then(|name| name.to_str()) {
+        if is_system_file(name)
+            || ["Windows", "Program Files", "Program Files (x86)", "ProgramData", "System Volume Information", "$Recycle.Bin"]
+                .iter()
+                .any(|protected| name.eq_ignore_ascii_case(protected))
+        {
+            return Err("Protected system path.".to_string());
+        }
+    }
+    ensure_recycle_supported(path)?;
+    Ok(())
+}
+
+#[cfg(windows)]
+fn ensure_recycle_supported(path: &Path) -> Result<(), String> {
+    use std::path::Component;
+    use windows_sys::Win32::Storage::FileSystem::{GetDriveTypeW, DRIVE_FIXED};
+
+    let mut components = path.components();
+    let Some(Component::Prefix(prefix)) = components.next() else {
+        return Err("Recycle Bin support could not be determined.".to_string());
+    };
+    if !matches!(components.next(), Some(Component::RootDir)) {
+        return Err("Recycle Bin support could not be determined.".to_string());
+    }
+    let root = format!("{}\\", prefix.as_os_str().to_string_lossy());
+    let wide = wide_null(&root);
+    let drive_type = unsafe { GetDriveTypeW(wide.as_ptr()) };
+    if drive_type == DRIVE_FIXED {
+        Ok(())
+    } else {
+        Err("Recycle Bin is only enabled for fixed local drives.".to_string())
+    }
+}
+
+#[cfg(not(windows))]
+fn ensure_recycle_supported(_path: &Path) -> Result<(), String> {
+    Ok(())
+}
+
+#[cfg(windows)]
+fn is_reparse_or_symlink(metadata: &fs::Metadata) -> bool {
+    use std::os::windows::fs::MetadataExt;
+    metadata.file_attributes() & windows_sys::Win32::Storage::FileSystem::FILE_ATTRIBUTE_REPARSE_POINT != 0
+}
+
+#[cfg(not(windows))]
+fn is_reparse_or_symlink(metadata: &fs::Metadata) -> bool {
+    metadata.file_type().is_symlink()
+}
+
+#[cfg(windows)]
+fn stable_path_id(path: &Path) -> u32 {
+    use std::os::windows::ffi::OsStrExt;
+    let mut hash = 0x811c9dc5u32;
+    for unit in path.as_os_str().encode_wide() {
+        let folded = if (b'A' as u16..=b'Z' as u16).contains(&unit) {
+            unit + 32
+        } else {
+            unit
+        };
+        hash = fnv_step(hash, (folded & 0xff) as u8);
+        hash = fnv_step(hash, (folded >> 8) as u8);
+    }
+    nonzero_hash(hash)
+}
+
+#[cfg(not(windows))]
+fn stable_path_id(path: &Path) -> u32 {
+    let mut hash = 0x811c9dc5u32;
+    for byte in path.to_string_lossy().bytes() {
+        hash = fnv_step(hash, byte.to_ascii_lowercase());
+    }
+    nonzero_hash(hash)
+}
+
+fn stable_rest_id(path: &Path) -> u32 {
+    let mut hash = stable_path_id(path);
+    for byte in b"#rest" {
+        hash = fnv_step(hash, *byte);
+    }
+    nonzero_hash(hash)
+}
+
+fn fnv_step(hash: u32, byte: u8) -> u32 {
+    (hash ^ byte as u32).wrapping_mul(16_777_619)
+}
+
+fn nonzero_hash(hash: u32) -> u32 {
+    if hash == 0 {
+        1
+    } else {
+        hash
+    }
+}
+
+#[cfg(windows)]
+fn platform_list_disks() -> Vec<DiskSummary> {
+    use windows_sys::Win32::Storage::FileSystem::{
+        GetDriveTypeW, GetLogicalDrives, DRIVE_FIXED, DRIVE_REMOVABLE,
+    };
+
+    let mask = unsafe { GetLogicalDrives() };
+    let mut disks = Vec::new();
+    for idx in 0..26 {
+        if mask & (1 << idx) == 0 {
+            continue;
+        }
+        let letter = (b'A' + idx as u8) as char;
+        let root = format!("{letter}:\\");
+        let wide = wide_null(&root);
+        let drive_type = unsafe { GetDriveTypeW(wide.as_ptr()) };
+        if drive_type != DRIVE_FIXED && drive_type != DRIVE_REMOVABLE {
+            continue;
+        }
+
+        if let Ok(summary) = disk_summary_for_root(letter, Path::new(&root)) {
+            disks.push(summary);
+        }
+    }
+    disks
+}
+
+#[cfg(not(windows))]
+fn platform_list_disks() -> Vec<DiskSummary> {
+    let root = Path::new("/");
+    let root_node = scan_dir(root, "/".to_string(), 0, SystemTime::now());
+    vec![DiskSummary {
+        letter: "/".to_string(),
+        label: "Root".to_string(),
+        total_bytes: root_node.size,
+        used_bytes: root_node.size,
+        available_bytes: 0,
+    }]
+}
+
+#[cfg(windows)]
+fn disk_summary_for_root(letter: char, root: &Path) -> Result<DiskSummary, String> {
+    use windows_sys::Win32::Storage::FileSystem::{GetDiskFreeSpaceExW, GetVolumeInformationW};
+
+    let root_string = root.to_string_lossy();
+    let root_wide = wide_null(&root_string);
+    let mut free_to_user = 0u64;
+    let mut total = 0u64;
+    let mut free_total = 0u64;
+    let ok = unsafe {
+        GetDiskFreeSpaceExW(
+            root_wide.as_ptr(),
+            &mut free_to_user,
+            &mut total,
+            &mut free_total,
+        )
+    };
+    if ok == 0 {
+        return Err(format!("Unable to read disk space for {letter}:"));
+    }
+
+    let mut label_buf = [0u16; 260];
+    let label_ok = unsafe {
+        GetVolumeInformationW(
+            root_wide.as_ptr(),
+            label_buf.as_mut_ptr(),
+            label_buf.len() as u32,
+            std::ptr::null_mut(),
+            std::ptr::null_mut(),
+            std::ptr::null_mut(),
+            std::ptr::null_mut(),
+            0,
+        )
+    };
+    let label = if label_ok != 0 {
+        let len = label_buf.iter().position(|ch| *ch == 0).unwrap_or(0);
+        String::from_utf16_lossy(&label_buf[..len])
+    } else {
+        String::new()
+    };
+
+    Ok(DiskSummary {
+        letter: letter.to_string(),
+        label: if label.is_empty() { "Local Disk".to_string() } else { label },
+        total_bytes: total,
+        used_bytes: total.saturating_sub(free_total),
+        available_bytes: free_to_user,
+    })
+}
+
+#[cfg(not(windows))]
+fn disk_summary_for_root(letter: char, root: &Path) -> Result<DiskSummary, String> {
+    let root_node = scan_dir(root, letter.to_string(), 0, SystemTime::now());
+    Ok(DiskSummary {
+        letter: letter.to_string(),
+        label: "Root".to_string(),
+        total_bytes: root_node.size,
+        used_bytes: root_node.size,
+        available_bytes: 0,
+    })
+}
+
+#[cfg(windows)]
+fn platform_open_in_explorer(path: &Path) -> Result<(), String> {
+    if !path.exists() {
+        return Err("Path does not exist.".to_string());
+    }
+    let mut command = std::process::Command::new("explorer.exe");
+    if path.is_file() {
+        command.arg(format!("/select,{}", path.to_string_lossy()));
+    } else {
+        command.arg(path);
+    }
+    command
+        .spawn()
+        .map(|_| ())
+        .map_err(|error| format!("Unable to open Explorer: {error}"))
+}
+
+#[cfg(not(windows))]
+fn platform_open_in_explorer(_path: &Path) -> Result<(), String> {
+    Err("Explorer integration is available on Windows.".to_string())
+}
+
+#[cfg(windows)]
+fn platform_recycle_one(path: &Path) -> Result<(), String> {
+    use windows_sys::Win32::UI::Shell::{
+        SHFileOperationW, SHFILEOPSTRUCTW, FO_DELETE, FOF_ALLOWUNDO, FOF_WANTNUKEWARNING,
+    };
+
+    let from = double_wide_null(path);
+    let mut operation = SHFILEOPSTRUCTW {
+        hwnd: std::ptr::null_mut(),
+        wFunc: FO_DELETE,
+        pFrom: from.as_ptr(),
+        pTo: std::ptr::null(),
+        fFlags: FOF_ALLOWUNDO | FOF_WANTNUKEWARNING,
+        fAnyOperationsAborted: 0,
+        hNameMappings: std::ptr::null_mut(),
+        lpszProgressTitle: std::ptr::null(),
+    };
+    let code = unsafe { SHFileOperationW(&mut operation) };
+    if code != 0 {
+        return Err(format!("Recycle operation failed with code {code}."));
+    }
+    if operation.fAnyOperationsAborted != 0 {
+        return Err("Recycle operation was aborted.".to_string());
+    }
+    Ok(())
+}
+
+#[cfg(not(windows))]
+fn platform_recycle_one(_path: &Path) -> Result<(), String> {
+    Err("Recycle Bin integration is available on Windows.".to_string())
+}
+
+#[cfg(windows)]
+fn wide_null(value: &str) -> Vec<u16> {
+    use std::os::windows::ffi::OsStrExt;
+    std::ffi::OsStr::new(value).encode_wide().chain([0]).collect()
+}
+
+#[cfg(windows)]
+fn double_wide_null(path: &Path) -> Vec<u16> {
+    use std::os::windows::ffi::OsStrExt;
+    path.as_os_str().encode_wide().chain([0, 0]).collect()
+}
+
+fn main() {
+    tauri::Builder::default()
+        .invoke_handler(tauri::generate_handler![
+            list_disks,
+            scan_disk,
+            open_in_explorer,
+            recycle_paths
+        ])
+        .run(tauri::generate_context!())
+        .expect("error while running FilesHousing");
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn scan_synthetic_tree_keeps_tree_bounded() {
+        let unique = SystemTime::now()
+            .duration_since(std::time::UNIX_EPOCH)
+            .unwrap()
+            .as_nanos();
+        let root = std::env::temp_dir().join(format!(
+            "fileshousing_scan_test_{}_{}",
+            std::process::id(),
+            unique
+        ));
+        fs::create_dir(&root).unwrap();
+
+        for dir_idx in 0..6 {
+            let dir = root.join(format!("dir_{dir_idx}"));
+            fs::create_dir(&dir).unwrap();
+            for file_idx in 0..12 {
+                let file = fs::File::create(dir.join(format!("file_{file_idx}.bin"))).unwrap();
+                file.set_len(((dir_idx + 1) * (file_idx + 1) * 1024) as u64)
+                    .unwrap();
+            }
+        }
+        for file_idx in 0..80 {
+            let file = fs::File::create(root.join(format!("loose_{file_idx}.dat"))).unwrap();
+            file.set_len(((file_idx + 1) * 512) as u64).unwrap();
+        }
+
+        let started = Instant::now();
+        let node = scan_dir(&root, "T:".to_string(), 0, SystemTime::now());
+        let elapsed = started.elapsed();
+        eprintln!(
+            "scanner timing check: {} files, {} bytes, {:?}",
+            node.count, node.size, elapsed
+        );
+
+        assert_eq!(node.count, 152);
+        assert!(node.children.as_ref().is_some_and(|children| children.len() <= ROOT_CHILDREN + 1));
+        for child in node.children.as_deref().unwrap_or(&[]) {
+            if let Some(children) = &child.children {
+                assert!(children.len() <= TOP_CHILDREN + 1);
+            }
+        }
+
+        fs::remove_dir_all(&root).unwrap();
+    }
+}
