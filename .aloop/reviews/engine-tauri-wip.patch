+++ b/src/backend.ts
@@ -0,0 +1,97 @@
+import { buildDisks } from './mockData';
+import type { CleanupResult, Disk, DiskSummary, FsNode } from './types';
+
+type Invoke = <T>(cmd: string, args?: Record<string, unknown>) => Promise<T>;
+
+let mockDisks: Disk[] | null = null;
+
+declare global {
+  interface Window {
+    __TAURI__?: {
+      core?: {
+        invoke?: Invoke;
+      };
+    };
+    __TAURI_INTERNALS__?: {
+      invoke?: Invoke;
+    };
+  }
+}
+
+export function isDesktopRuntime(): boolean {
+  return typeof window !== 'undefined'
+    && (typeof window.__TAURI__?.core?.invoke === 'function'
+      || typeof window.__TAURI_INTERNALS__?.invoke === 'function');
+}
+
+function getInvoke(): Invoke | null {
+  if (!isDesktopRuntime()) return null;
+  const invoke = window.__TAURI__?.core?.invoke ?? window.__TAURI_INTERNALS__!.invoke!;
+  return <T>(cmd: string, args?: Record<string, unknown>) => invoke(cmd, args) as Promise<T>;
+}
+
+function fallbackDisks(): Disk[] {
+  mockDisks ??= buildDisks();
+  return mockDisks;
+}
+
+function summarize(disk: Disk): DiskSummary {
+  const usedBytes = disk.root.size;
+  return {
+    letter: disk.letter,
+    label: disk.label,
+    totalBytes: disk.totalBytes,
+    usedBytes,
+    availableBytes: Math.max(0, disk.totalBytes - usedBytes),
+  };
+}
+
+function hydrateNode(node: FsNode, parent: FsNode | null): void {
+  node.parent = parent;
+  delete node.mapChildren;
+  delete node.rect;
+  delete node.vis;
+  delete node.visGen;
+  for (const child of node.children ?? []) hydrateNode(child, node);
+}
+
+function hydrateDisk(disk: Disk): Disk {
+  hydrateNode(disk.root, null);
+  return disk;
+}
+
+export async function listDiskSummaries(): Promise<DiskSummary[]> {
+  const invoke = getInvoke();
+  if (!invoke) return fallbackDisks().map(summarize);
+  return invoke<DiskSummary[]>('list_disks');
+}
+
+export async function scanDisk(summary: DiskSummary): Promise<Disk> {
+  const invoke = getInvoke();
+  if (!invoke) {
+    const disk = fallbackDisks().find(d => d.letter === summary.letter) ?? fallbackDisks()[0];
+    return hydrateDisk(disk);
+  }
+  return hydrateDisk(await invoke<Disk>('scan_disk', { letter: summary.letter }));
+}
+
+export async function openInExplorer(path: string): Promise<boolean> {
+  const invoke = getInvoke();
+  if (!invoke) return false;
+  await invoke<void>('open_in_explorer', { path });
+  return true;
+}
+
+export async function recyclePaths(paths: string[]): Promise<CleanupResult> {
+  const invoke = getInvoke();
+  if (!invoke) {
+    return {
+      requested: paths.length,
+      recycled: 0,
+      failed: paths.length,
+      recycledPaths: [],
+      errors: paths.map(path => ({ path, error: 'Desktop app required for recycle operations.' })),
+    };
+  }
+  return invoke<CleanupResult>('recycle_paths', { paths });
+}
